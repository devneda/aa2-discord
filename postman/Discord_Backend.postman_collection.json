            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Kevin\",\n  \"email\": \"kevin@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
